{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "iShyom",
  "alternateName": "iShyom",
  "url": "https://www.ishyom.com/",
  "description": "Creative services for your business",
  "publisher": {
    "@type": "Organization",
    "name": "iShyom",
    "logo": {
      "@type": "ImageObject",
      "url": "https://www.ishyom.com//logo.png"
    }
  },
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "https://www.ishyom.com//search?q={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  }
}